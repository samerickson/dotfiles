#!/usr/bin/env bash

NOTE_DIR="$HOME/notes"
DAILY_DIR="$NOTE_DIR/daily"
DATE=${ date +%F; }

next_business_day() {
    case "$(date +%u)" in
        5) date -d "3 days" +%F ;; # Friday -> Monday
        6) date -d "2 days" +%F ;; # Saturday -> Monday
        *) date -d "1 day" +%F ;;  # Sunday-Thursday -> Next day
    esac
}

open_file() {
    if [[ "$EDITOR" == "nvim" ]]; then
        if [[ ! -z "$NVIM" ]]; then
            # Command was executed within an nvim instance, so open the file using
            # that instance.

            nvim --server "$NVIM" --remote-tab "$1"
            return 0
        fi
    fi

    "$EDITOR" "$1"
}

daily() {
    local TARGET_DATE="$DATE"

    if [[ $# -gt 0 ]]; then
        if [[ "$1" == "next" ]]; then
            shift
            TARGET_DATE=${ next_business_day; }
        elif [[ "$1" == "today" ]]; then
            # This is the default behaviour
            shift
        elif [[ "$1" == "yesterday" ]]; then
            shift
            TARGET_DATE=${ date -d "-1 day" +%F; }
        elif [[ "$1" == "date" ]]; then
            shift
            if [[ -z "$1" ]]; then
                echo "must pass date"
                return 1
            fi

            TARGET_DATE="$1"
        else
            echo "unknown arg: $1"
            return 1
        fi
    fi

    # If no params default to opening todays daily note
    local FILE="$DAILY_DIR/$TARGET_DATE.md"

    # Check if user requested just returning the path in the remaining arguments
    for arg in "$@"; do
        if [[ "$arg" == "--path" ]]; then
            echo "$FILE"
            return
        fi
    done

    mkdir -p "$DAILY_DIR"

    if [[ ! -f "$FILE" ]]; then
        cat > "$FILE" <<EOF
# Daily $TARGET_DATE

## Tasks

- [ ]

## Notes


## Log


EOF
    fi

    open_file "$FILE"
}

case "$1" in
    daily)
        shift
        daily "$@"
        ;;
    *)
        echo "Usage: notes {daily}"
        exit 1
        ;;
esac
